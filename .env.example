# ── Discord ──────────────────────────────────────────────────────────────
# Token del bot (Discord Developer Portal → Bot → Token)
DISCORD_TOKEN=your_discord_bot_token_here

# Client ID del bot (Discord Developer Portal → General Information → Application ID)
DISCORD_CLIENT_ID=your_discord_client_id_here

# ID del servidor donde registrar los slash commands (Guild ID)
# Déjalo vacío para registrar los comandos globalmente (tarda ~1 hora)
DISCORD_GUILD_ID=your_guild_id_here

# ── Firebase ─────────────────────────────────────────────────────────────
# Ruta al archivo JSON de la cuenta de servicio (dentro del contenedor)
# Opción A: ruta al archivo montado vía Docker volume
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Opción B: credenciales en base64 (útil en CI/CD sin archivos)
# Genera el valor con:  base64 -i serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_B64=<base64_del_json>

# Bucket de Firebase Storage (encontrado en Firebase Console → Storage)
# Formato: tu-proyecto.appspot.com  o  tu-proyecto.firebasestorage.app
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Nombre de la colección de Firestore donde están las canciones
FIREBASE_SONGS_COLLECTION=songs
